{{!
    @template theme_boost_union/recommendationsdetailsmodal

    Boost Union recommendation details modal template.

    Example context (json):
    {
        "title": "Enable slash arguments",
        "summary": "Short summary",
        "description": "Long description",
        "statuslabel": "Warning",
        "statusbadgeclass": "text-bg-warning",
        "statusdescription": "This recommendation needs your attention."
    }
}}
<div class="theme_boost_union-recommendationdetails-modal">
    {{#summary}}
        <p><strong>{{summary}}</strong></p>
    {{/summary}}
    {{#description}}
        <p>{{description}}</p>
    {{/description}}
    {{#statusdescription}}
        <p><strong>{{#str}}recommendationcurrentstatus, theme_boost_union{{/str}}</strong><br />
        <span class="badge {{statusbadgeclass}}">{{statuslabel}}</span> {{statusdescription}}</p>
    {{/statusdescription}}
    {{#possiblesolution}}
        <p><strong>{{#str}}recommendationpossiblesolutions, theme_boost_union{{/str}}</strong><br />
        {{possiblesolution}}</p>
    {{/possiblesolution}}
</div>
