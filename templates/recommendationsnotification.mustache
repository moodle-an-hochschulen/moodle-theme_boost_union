{{!
    @template theme_boost_union/recommendationsnotification

    Template for rendering a single recommendation notification in settings descriptions.

    Context variables required for this template:
    * statuslabel - The status label
    * statusbadgeclass - The bootstrap badge class for status
    * recommendationtitle - The recommendation title
    * actionshtml - Pre-rendered action icons HTML
}}
<div class="theme-boost-union-recommendationnotification">
    <div class="row g-2 align-items-start">
        <div class="col-12 col-md pe-3">
            <strong>{{#str}}recommendationsnotificationtitle, theme_boost_union{{/str}}: {{recommendationtitle}}</strong><br />
            <span class="badge {{statusbadgeclass}} me-1">{{statuslabel}}</span>{{recommendationsummary}}
        </div>
        <div class="col-12 col-md-auto recommendations-actions text-start text-md-end">
            {{{actionshtml}}}
        </div>
    </div>
</div>
