{{!
    @template theme_boost_union/settingoverridenotification

    Template for rendering a setting override notification in settings descriptions.

    Context variables required for this template:
    * message - The main notification message
    * actionshtml - Pre-rendered action buttons HTML (optional)
}}
<div class="theme-boost-union-settingoverridenotification">
    <div class="row g-2 align-items-start">
        <div class="col-12 col-md pr-3">
            <strong>{{#str}}settingoverridenotificationtitle, theme_boost_union{{/str}}</strong><br />
            {{message}}
        </div>
        <div class="col-12 col-md-auto settingoverride-actions text-start text-md-end">
            {{{actionshtml}}}
        </div>
    </div>
</div>
